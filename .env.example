# Copia este archivo a .env y rellena los valores
# cp .env.example .env

# Wallet del deployer / host de la demo
PRIVATE_KEY=0x...

# Wallets adicionales para la demo (jugadores 2 y 3)
PLAYER2_KEY=0x...
PLAYER3_KEY=0x...

# Se rellena automáticamente después del deploy
TEMPO_ADDRESS=0x...

# API key del explorer de Monad (para verificación)
MONADEXPLORER_API_KEY=your_api_key_here
